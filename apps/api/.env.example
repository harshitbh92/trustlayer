DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustlayer
REDIS_URL=redis://localhost:6379
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Change in production
JWT_SECRET=dev-secret-change-me-in-production

# Optional: created/updated by `npm run db:seed -w @trustlayer/api`
ADMIN_EMAIL=admin@trustlayer.local
ADMIN_PASSWORD=change-me-admin-password
# Optional: public base URL for uploaded media links
# API_PUBLIC_URL=http://localhost:4000

# Email (OTP + moderation)
# Prefer Resend on Railway: Hobby/Free block outbound SMTP ports.
# https://resend.com — free tier works over HTTPS.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=TrustLayer <onboarding@resend.dev>
# After verifying a domain in Resend, use e.g. TrustLayer <noreply@yourdomain.com>

# SMTP (local / Railway Pro+ only — Hobby blocks smtp.gmail.com:587/465)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=TrustLayer <noreply@example.com>

# Reputation AI assist (optional)
# Heuristic tag assist always runs. Set these to also call OpenAI.
# REPUTATION_AI_ENABLED=true
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
